# Sentry Configuration
# For local Sentry (Docker): http://localhost:9000
# For Sentry SaaS: https://your-project.sentry.io
SENTRY_DSN=http://localhost:9000/1
NODE_ENV=development
SENTRY_RELEASE=1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_DEBUG=false
SENTRY_ENABLE_PERFORMANCE_MONITORING=false
SENTRY_ENABLE_TRACING=false

# Web Sentry Configuration
VITE_SENTRY_DSN=http://localhost:9000/1
VITE_SENTRY_RELEASE=1.0.0
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_PROFILES_SAMPLE_RATE=0.1
VITE_SENTRY_DEBUG=false
