# ============================================
# Root Environment Variables (Docker Compose)
# ============================================

# Environment
NODE_ENV=development

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=seat_booking
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/seat_booking

# MongoDB Configuration
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_URI=mongodb://localhost:27017/seat_booking

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URI=redis://localhost:6379

# AWS / LocalStack Configuration
AWS_ENDPOINT=http://localhost:4566
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
SQS_QUEUE_URL=http://localhost:4566/000000000000/seat-booking-orders.fifo

# Sentry Configuration
# For local Sentry (Docker): http://localhost:9000
# For Sentry SaaS: https://your-project.sentry.io
SENTRY_DSN=http://7b1c48d3e9f0a2b5c6d7e8f9a0b1c2d3@localhost:9000/1
SENTRY_RELEASE=1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_DEBUG=false
SENTRY_ENABLE_PERFORMANCE_MONITORING=false
SENTRY_ENABLE_TRACING=false
