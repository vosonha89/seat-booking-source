# ============================================
# Payment Service Configuration
# ============================================

# Service Configuration
PORT=3003
NODE_ENV=development

# PostgreSQL Configuration
POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/seat_booking

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/seat_booking

# AWS / LocalStack Configuration
AWS_ENDPOINT=http://localhost:4566
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
SQS_QUEUE_URL=http://localhost:4566/000000000000/seat-booking-orders.fifo

# Payment Gateway Configuration
PAYMENT_GATEWAY_URL=http://localhost:3004
WEBHOOK_SECRET=whsec_your-webhook-secret-key

# Sentry Configuration
SENTRY_DSN=http://localhost:9000/1
SENTRY_RELEASE=1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_DEBUG=false
SENTRY_ENABLE_PERFORMANCE_MONITORING=false
SENTRY_ENABLE_TRACING=false
