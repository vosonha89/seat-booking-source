{
  "compilerOptions": {
	"strict": true,
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": false,
    "paths": {"*": ["./*"]},
    "paths": {
      "@seat-booking/base-logging": ["../base-logging/src/index.ts"],
      "@seat-booking/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@seat-booking/shared-errors": ["../../packages/shared-errors/src/index.ts"],
      "@seat-booking/database": ["../../packages/database/src/index.ts"]
    }
  }
}
