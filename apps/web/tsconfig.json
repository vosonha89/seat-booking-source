{
"compilerOptions": {
"target": "ES2022",
"useDefineForClassFields": true,
"lib": ["ES2022", "DOM", "DOM.Iterable"],
"module": "ESNext",
"skipLibCheck": true,
"moduleResolution": "Bundler",
"resolveJsonModule": true,
"isolatedModules": true,
"noEmit": true,
"jsx": "react-jsx",
"strict": true,
    "types": ["vite/client", "node", "vitest"],
    "baseUrl": ".",
    "paths": {
        "@seat-booking/shared-types": ["../../packages/shared-types/dist"],
        "@seat-booking/shared-types/*": ["../../packages/shared-types/dist/*"]
    }
},
"include": ["src"],
"exclude": ["src/**/*.spec.tsx", "src/jest.setup.ts"]
}
