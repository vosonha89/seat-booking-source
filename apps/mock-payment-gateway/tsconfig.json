{
  "compilerOptions": {
	"strict": true,
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@seat-booking/base-logging": ["../base-logging/dist/index.js"],
      "@seat-booking/shared-types": ["../../packages/shared-types/dist/index.js"],
      "@seat-booking/shared-errors": ["../../packages/shared-errors/dist/index.js"],
      "@seat-booking/database": ["../../packages/database/dist/index.js"]
    }
  }
}
