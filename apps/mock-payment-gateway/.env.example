SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_DEBUG=false
SENTRY_ENABLE_PERFORMANCE_MONITORING=false
SENTRY_ENABLE_TRACING=false
